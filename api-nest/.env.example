# ===================================
# Nexus SaaS — Environment Variables
# Copy this file to .env and fill in values
# ===================================

# Database
DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/nexus_saas

# JWT
JWT_SECRET=your_very_long_random_secret_here_at_least_64_chars
JWT_ACCESS_EXPIRES_MIN=15
JWT_REFRESH_EXPIRES_DAYS=7

# MinIO / S3
MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_PUBLIC_URL=https://s3.yourdomain.com
MINIO_ACCESS_KEY=nexusadmin
MINIO_SECRET_KEY=YourMinioSecret123!
MINIO_BUCKET=nexus-generations

# Stripe
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# Frontend URL (for Stripe redirects)
FRONTEND_URL=https://yourdomain.com

# Groq AI
GROQ_API_KEY=your_groq_api_key_here

# CORS
CORS_ORIGINS=https://yourdomain.com,http://localhost:5173

# Email (SMTP for password reset / verification)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
SMTP_FROM=Nexus AI <noreply@yourdomain.com>
